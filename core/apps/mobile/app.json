{
  "expo": {
    "name": "TaskFlow",
    "slug": "taskflow",
    "version": "1.0.0",
    "scheme": "taskflow",
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.shipshit.taskflow"
    },
    "android": {
      "package": "dev.shipshit.taskflow"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#3B82F6",
          "sounds": [],
          "androidMode": "default"
        }
      ]
    ]
  }
}
