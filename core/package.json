{
  "description": "Full-stack task management application — open-source core",
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@playwright/test": "1.58.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@vitejs/plugin-react": "5.1.2",
    "@vitest/coverage-v8": "4.0.18",
    "husky": "9.1.7",
    "jsdom": "27.4.0",
    "lint-staged": "16.2.7",
    "vitest": "4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": [
      "bunx biome check --write"
    ]
  },
  "name": "taskflow-core",
  "packageManager": "bun@latest",
  "private": true,
  "scripts": {
    "build": "bun run --cwd apps/api build && bun run --cwd apps/web build",
    "check": "biome check .",
    "deps:update": "bunx npm-check-updates -u && bun install",
    "dev": "bun run --cwd apps/api dev & bun run --cwd apps/web dev",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:desktop": "bun run --cwd apps/desktop dev",
    "dev:mobile": "bun run --cwd apps/mobile start",
    "dev:web": "bun run --cwd apps/web dev",
    "format": "biome format --write .",
    "format:check": "biome format --check .",
    "lint": "biome check .",
    "start": "bun --filter '*' run start",
    "test": "NODE_ENV=test vitest run",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "test:watch": "NODE_ENV=test vitest"
  },
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "../packages/*"
  ]
}
