{
  "description": "Full-stack task management application — OSS core + SaaS cloud",
  "name": "taskflow",
  "packageManager": "bun@latest",
  "private": true,
  "scripts": {
    "build": "cd core && bun run build",
    "check": "cd core && bun run check",
    "cloud:build": "cd cloud && bun run build",
    "cloud:dev": "cd cloud && bun run dev",
    "deps:update": "bunx npm-check-updates -u && bun install",
    "dev": "cd core && bun run dev",
    "dev:api": "cd core && bun run dev:api",
    "dev:desktop": "cd core && bun run dev:desktop",
    "dev:mobile": "cd core && bun run dev:mobile",
    "dev:web": "cd core && bun run dev:web",
    "format": "cd core && bun run format",
    "lint": "cd core && bun run lint",
    "test": "cd core && NODE_ENV=test bun run test",
    "test:coverage": "cd core && NODE_ENV=test bun run test:coverage"
  },
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ]
}
